{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Janela principal: diálogos nativos + leitura/escrita de arquivos de projeto escolhidos pelo usuário",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "**" }]
    }
  ]
}
